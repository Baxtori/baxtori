# Create a GitHub App with read-only Contents and Metadata repository permissions.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_SLUG=
# Use at least 32 random bytes. This encrypts GitHub tokens in HttpOnly cookies.
GITHUB_SESSION_SECRET=
# Server-only Convex bridge. Do not prefix either value with NEXT_PUBLIC_.
CONVEX_URL=
FEEDBACK_API_SECRET=
# GitHub login whose feedback the local weekly compiler consumes.
FEEDBACK_GITHUB_LOGIN=
